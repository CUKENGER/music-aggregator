{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "app-api": {
      "type": "application",
      "root": "apps/app-api",
      "entryFile": "main",
      "sourceRoot": "apps/app-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/app-api/tsconfig.app.json"
      }
    },
    "app-worker": {
      "type": "application",
      "root": "apps/app-worker",
      "entryFile": "main",
      "sourceRoot": "apps/app-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/app-worker/tsconfig.app.json"
      }
    }
  }
}
